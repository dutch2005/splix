{
  "version": 6,
  "configurePresets": [
    {
      "name": "linux-amd64-release",
      "displayName": "Linux AMD64 Release",
      "description": "Release build targeting Linux AMD64",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-amd64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-arm64-release",
      "displayName": "Linux ARM64 Release",
      "description": "Cross-compile Release build targeting Linux ARM64",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-arm64",
      "toolchainFile": "${sourceDir}/cmake/toolchain-arm64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "description": "Debug build",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-amd64-release",
      "configurePreset": "linux-amd64-release"
    },
    {
      "name": "linux-arm64-release",
      "configurePreset": "linux-arm64-release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    }
  ],
  "testPresets": [
    {
      "name": "linux-amd64-release",
      "configurePreset": "linux-amd64-release",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "linux-arm64-release",
      "configurePreset": "linux-arm64-release",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "output": {"outputOnFailure": true}
    }
  ],
  "packagePresets": [
    {
      "name": "linux-amd64-release",
      "configurePreset": "linux-amd64-release"
    },
    {
      "name": "linux-arm64-release",
      "configurePreset": "linux-arm64-release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    }
  ]
}
