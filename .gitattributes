# Auto detect text files and normalise line endings to LF in the repo.
* text=auto

# Shell scripts MUST use LF line endings on all platforms (bash won't
# parse \r\n and will fail with "$'\r': command not found").
*.sh     text eol=lf
*.bash   text eol=lf

# Keep Windows scripts with CRLF
*.ps1    text eol=crlf
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Source code — normalise to LF in the repo
*.cpp    text eol=lf
*.h      text eol=lf
*.cmake  text eol=lf
CMakeLists.txt text eol=lf
Dockerfile     text eol=lf

# Binary files
*.ppd    binary
*.deb    binary
*.rpm    binary
